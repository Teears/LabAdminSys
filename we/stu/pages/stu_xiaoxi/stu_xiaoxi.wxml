<!--stu/pages/stu_xiaoxi/stu_xiaoxi.wxml-->
<import src="/template/basictp.wxml" />
<view class="out_wrapper">
  <van-cell center clickable label="{{item.title}}" wx:for="{{list}}" bind:click="showPopup" data-index="{{index}}">
    <view slot="title">
      <text>{{item.type}}</text>
      <van-icon custom-class="dot" wx:if="{{item.dot}}" dot />
    </view>
    <view>
      <text>{{item.day}}\n{{item.time}}</text>
    </view>
  </van-cell>

  <van-popup round custom-class="popup" show="{{dialogShow}}" bind:close="tapDialogButton">
    <view class="popup_title">
      {{list[index].title}}
    </view>
    <view class="popup_content">
      <text>{{list[index].content}}</text>
    </view>
  </van-popup>

  <view class="loading" wx:if="{{loading}}">
    <van-loading text-size="6" type="spinner" />
  </view>
  <view class="loading_text" wx:if="{{last}}">————没有更多数据了————</view>
  <view class="loading_text" wx:if="{{loadingFail}}">————网络故障————</view>
</view>