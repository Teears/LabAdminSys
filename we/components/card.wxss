/* components/card.wxss */
@import "/style/iconfont.wxss";
.card{
  /* transform-style:preserve-3d;
  transform-origin:0% center; */
  perspective: 2500rpx
}
.box{
  position: absolute;
  backface-visibility: hidden;
  height: 100%;
  width: 100%;
}
/* 背景样式 */
.sky{
  background-color: #0D0847;
  border-radius: 20rpx;
  text-align: center;
  height: 100%;
  width: 100%;
}
/* 上下布局 */
.top{
  position: relative;
  text-align: center;
}
.bottom{
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  color: aliceblue;
}
/* 日历样式 */
.calendar{
  height: 50%;
  width: 150rpx;
  border: thin solid rgb(221, 221, 221);
}
.date{
  height: 50%;
  font-size: xx-large;
  line-height: 100%;
  padding-top: 5rpx;
}
.day{
  font-size: x-small;
  height: 20%;
  border-bottom: thin solid rgb(221, 221, 221);
  padding: 2rpx;
  line-height: 100%;
}
.year_month{
  height: 30%;
  font-size: small
}
/* 下方提示文字样式 */
.bottom text{
  margin: 30rpx;
  font-size: xx-large  ;
} 
/* 插画样式 */
.main{
  width: 90%;
}
.leftTop{
  height: 150rpx;
  width: 150rpx;
  position: absolute;
  top: 50rpx;
  left: 50rpx;
}
.rightTop{
  height: 150rpx;
  width: 150rpx;
  position: absolute;
  top: 50rpx;
  right: 50rpx;
}
.leftBottom{
  height: 150rpx;
  width: 150rpx;
  position: absolute;
  bottom: 50rpx;
  left: 50rpx;
}
.rightBottom{
  height: 150rpx;
  width: 150rpx;
  position: absolute;
  bottom: 50rpx;
  right: 50rpx;
}

/* 
背面样式
 */
.back{
  background-image: linear-gradient(to bottom,#FF9966,#FF5E62);
  border-radius: 20rpx;
  text-align: center;
  transform: rotateY(-180deg);
}
.back text{
  font-size: x-large;
  color: white;
}
.iconfont{
  font-size: 1200%;
  color: white;
  font-weight: 900;
}